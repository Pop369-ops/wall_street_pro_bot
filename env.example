# ═══════════════════════════════════════════════════════════════
#  WALL STREET PRO BOT V4 — Environment Variables
# ═══════════════════════════════════════════════════════════════
#  انسخ هذا الملف باسم .env واملأ القيم
#  أو ضعها مباشرة في Railway Variables
# ═══════════════════════════════════════════════════════════════

# 🤖 Telegram (مطلوب)
BOT_TOKEN=ضع_توكن_البوت_من_BotFather

# 🧠 AI APIs (مطلوبة - الـ3 موصى بها للإجماع)
CLAUDE_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...

# 📊 Market Data APIs (الـStack المعتمد)
POLYGON_API_KEY=                    # https://polygon.io/dashboard
TRADING_ECON_KEY=user:password      # https://tradingeconomics.com/api - format "user:pass"
DATABENTO_API_KEY=db-...             # https://databento.com (اختياري - للـCME tick data)
FRED_API_KEY=                        # https://fred.stlouisfed.org/docs/api/api_key.html (مجاني)

# 💾 Database
DB_PATH=wallstreet_bot.db
